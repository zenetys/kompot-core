#### _linux ####
define host {
  register             0
  name                 _linux
  use                  generic-host
}
define service {
  __WARNING            300
  __CRITICAL           330
  register             0
  name                 _linux:nb-process
  display_name         NB-PROCESS
  use                  generic-service
}

#### testhost1:_linux ####
define host {
  contact_groups       admins
  host_name            testhost1
  display_name         testhost1
  address              192.168.1.1
  use                  _linux
}
define service {
  __WARNING            111
  contact_groups       admins,grp_test
  service_description  NB-PROCESS
  display_name         NB-PROCESS
  host_name            testhost1
  use                  _linux:nb-process
}

