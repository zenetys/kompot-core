define service {
  check_command        check-dummy
  __WARNING            80
  __CRITICAL           90
  register             0
  name                 snmp-linux-swap
  use                  generic-service
}
#### _linux ####
define host {
  register             0
  name                 _linux
  use                  generic-host
}
define service {
  register             0
  name                 _linux:swap
  display_name         SWAP
  use                  snmp-linux-swap
}
define service {
  __PORT               22
  register             0
  name                 _linux:adm-ssh
  display_name         ADM-SSH
  use                  generic-service
}

#### _debian:_linux ####
define host {
  register             0
  name                 _debian
  use                  _linux
}

#### _debian2244:_debian ####
define host {
  register             0
  name                 _debian2244
  use                  _debian
}
define service {
  __PORT               2244
  register             0
  name                 _debian2244:adm-ssh
  display_name         ADM-SSH
  use                  generic-service
}

#### vipi:_debian2244 ####
define host {
  host_name            vipi
  display_name         vipi
  address              192.168.0.1
  use                  _debian2244
}
define service {
  __WARNING            100
  service_description  SWAP
  display_name         SWAP
  host_name            vipi
  use                  _linux:swap
}
define service {
  service_description  ADM-SSH
  display_name         ADM-SSH
  host_name            vipi
  use                  _debian2244:adm-ssh
}

